    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n  const notifications = item.json.data;\n  item.json.attachments = [];\n  \n  if(notifications.length == 0) {\n    item.json.text += \"\\n\\n_You don't have any lunch alerts configured right now_\";\n  } else {\n    item.json.text_command = notifications.map(it => \"* `\" + it.diet + \"`: \" + it.query).join(\"\\n\");\n    item.json.attachments = notifications.map(it => {\n      return {\n        color: \"#3a70f4\",\n        text: \"**Keyword:** \" + it.query + \" - **Diet**: \" + it.diet,\n        actions: [\n          {\n            id: \"del\" + it.query + it.user_id, \n            name: \"🗑️ Remove Alert\",\n            type: \"button\",\n            style: \"danger\",\n            integration: {\n              url: item.json.webhook_url,\n              context: {\n                action: \"delete_alert\",\n                keyword: it.query\n              }\n            }\n          }\n        ]\n      }\n    });\n  }\n\n  item.json.attachments.push({\n    color: \"#2ecc71\",\n    text: \"**⚙️ Actions**\",\n    actions: [\n      {\n        id: \"triggeraddomdal\", \n        name: \"➕ Add New Alert\",\n        type: \"button\",\n        style: \"primary\",\n        integration: {\n          url: item.json.webhook_url,\n          context: {\n            action: \"open_add_dialog\"\n          }\n        }\n      }\n    ]\n  });\n}\n\nreturn $input.all();"
      },
