    },
    {
      "parameters": {
        "jsCode": "const LF = '  \\n';\n\nfor (const item of $input.all()) {\n  const headline = `##### [Today's Menu](https://seezeit.com/essen/speiseplaene/mensa-giessberg/) (${item.json.date})`;\n\n  const thead = '| Category | Description | Tags |';\n  const tdef = '| :--- | :--- | :--- |';\n  const tbody = item.json.data.map(it => {\n    return `| ${it.category} | ${it.title} | ${it.icons} |`;\n  }).join(LF);\n\n  const table = [thead, tdef, tbody].join(LF);\n  \n  item.json.text = [headline, table].join(LF);\n  item.json.response_type = 'in_channel';\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
