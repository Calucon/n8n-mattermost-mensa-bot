    {
      "parameters": {
        "jsCode": "const emojiMap = new Map([\n  ['23', ':star:'],\n  ['24', ':leafy_green:'],\n  ['45', ':pig:'],\n  ['46', ':cow:'],\n  ['47', ':pig:'],\n  ['49', ':chicken:'],\n  ['50', ':fish:'],\n  ['51', ':carrot:'],\n  ['52', ':deer:'],\n]);\n\nfor (const item of $input.all()) {\n  const icons = (item.json?.icons ?? '')\n    .split(',')\n    .map(it => it.trim())\n    .map(it => emojiMap.get(it) ?? it)\n    .join(' ');\n\n  item.json.icons = icons;\n\n  item.json.isVegan = icons.includes(\":leafy_green:\");\n  item.json.isVegetarian = item.json.isVegan || icons.includes(\":carrot:\");\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        448
      ],
