    {
      "parameters": {
        "jsCode": "function capitalizeFirstLetter(str) {\n  if (!str) return '';\n\n  var firstCodeUnit = str[0];\n\n  if (firstCodeUnit < '\\uD800' || firstCodeUnit > '\\uDFFF') {\n    return str[0].toUpperCase() + str.slice(1);\n  }\n\n  return str.slice(0, 2).toUpperCase() + str.slice(2);\n}\n\nfor (const item of $input.all()) {\n  item.json.category = capitalizeFirstLetter(item.json?.category ?? 'unknown');\n  item.json.title = capitalizeFirstLetter(item.json?.title ?? 'unknown');\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        432,
        448
      ],
      "id": "0039e9a5-0a3a-4a8f-808f-eb113038ede5",
