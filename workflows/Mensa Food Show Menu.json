      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n  const alerts = new Set(\n    item.json.data\n    .filter(it => it.alerts)\n    .map(it => it.alerts)\n    .flat()\n    .sort()\n  );\n\n  if(alerts) {\n    item.json.text += `\\n\\n---`;\n    for(const alert of alerts) {\n      item.json.text += `\\n${alert}`;\n    }\n  }\n}\n\nreturn $input.all();"
      },
